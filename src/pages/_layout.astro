---
import '../styles/global.css';
import { site, text, languages, pathFor } from '../content/site.js';

const {
  lang = 'ru',
  title = `${site.name} — финансы, бюджеты и отчёты`,
  description = 'Contivo помогает вести доходы и расходы, создавать бюджеты, планировать цели и экспортировать отчёты в PDF и Excel.',
  currentPath = '/',
} = Astro.props;

const t = text[lang];
const analyticsId = 'G-KVYG4BB9QT';
const canonicalUrl = `https://contivoapp.com${pathFor(lang, currentPath)}`;
const ogImage = 'https://contivoapp.com/og-image.png';

const nav = [
  { label: t.nav.home, href: pathFor(lang, '/') },
  { label: t.nav.help, href: pathFor(lang, '/help') },
  { label: t.nav.news, href: pathFor(lang, '/news') },
  { label: t.nav.contact, href: pathFor(lang, '/contact') },
];

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://contivoapp.com/#organization',
      name: 'Contivo',
      url: 'https://contivoapp.com',
      logo: 'https://contivoapp.com/icon.png',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://contivoapp.com/#website',
      url: 'https://contivoapp.com',
      name: 'Contivo',
      publisher: { '@id': 'https://contivoapp.com/#organization' },
      inLanguage: lang,
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://contivoapp.com/#software',
      name: 'Contivo',
      applicationCategory: 'FinanceApplication',
      operatingSystem: 'Android, iOS, Web',
      url: 'https://contivoapp.com',
      image: ogImage,
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'EUR',
      },
      publisher: { '@id': 'https://contivoapp.com/#organization' },
    },
  ],
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Contivo" />
    <meta name="theme-color" content="#6d35d4" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <script async src={`https://www.googletagmanager.com/gtag/js?id=${analyticsId}`} />
    <script is:inline define:vars={{ analyticsId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', analyticsId, {
        anonymize_ip: true,
      });
    </script>
  </head>
  <body>
    <header class="header">
      <div class="container navbar">
        <a class="logo" href={pathFor(lang, '/')}> 
          <img class="logo-img" src="/logo.png" alt="Contivo logo" />
          <span>{site.name}</span>
        </a>
        <nav class="nav-links">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <div class="nav-actions">
          <select class="language-select" aria-label="Language" onchange="window.location.href=this.value">
            {languages.map((item) => (
              <option value={pathFor(item.code, currentPath)} selected={item.code === lang}>{item.label}</option>
            ))}
          </select>
          <a class="btn btn-primary" href={pathFor(lang, '/contact')}>{t.nav.support}</a>
        </div>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="container footer-grid">
        <div>© {new Date().getFullYear()} {site.name}. {t.footer.rights}</div>
        <div class="footer-links">
          <a href={pathFor(lang, '/privacy')}>{t.footer.privacy}</a>
          <a href={pathFor(lang, '/terms')}>{t.footer.terms}</a>
          <a href={pathFor(lang, '/help')}>{t.footer.help}</a>
          <a href={pathFor(lang, '/contact')}>{t.footer.contact}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
