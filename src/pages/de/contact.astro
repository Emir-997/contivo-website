---
import Layout from '../_layout.astro';
import ContactPage from '../../components/ContactPage.astro';
import { site } from '../../content/site.js';
import { legalText } from '../../content/legal.js';
const lang = 'de';
const content = legalText[lang];
---
<Layout lang={lang} currentPath="/contact" title={`${content.contact.title} — Contivo`} description={content.contact.intro}>
  <ContactPage content={content.contact} supportEmail={site.supportEmail} privacyEmail={site.privacyEmail} domain={site.domain} />
</Layout>
