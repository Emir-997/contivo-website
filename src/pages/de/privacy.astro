---
import Layout from '../_layout.astro';
import LegalPage from '../../components/LegalPage.astro';
import { legalText } from '../../content/legal.js';
const lang = 'de';
const content = legalText[lang];
---
<Layout lang={lang} currentPath="/privacy" title={`${content.privacy.title} — Contivo`} description={content.privacy.intro}>
  <LegalPage {...content.privacy} updated={content.common.updated} note={content.common.note} />
</Layout>
