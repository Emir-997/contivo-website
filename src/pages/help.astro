---
import Layout from './_layout.astro';
import SupportPage from '../components/SupportPage.astro';
import { legalText } from '../content/legal.js';
const lang = 'en';
const content = legalText[lang];
---
<Layout lang={lang} currentPath="/help" title={`${content.support.title} — Contivo`} description={content.support.intro}>
  <SupportPage {...content.support} />
</Layout>
