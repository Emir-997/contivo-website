---
import Layout from './_layout.astro';
import LegalPage from '../components/LegalPage.astro';
import { legalText } from '../content/legal.js';
const lang = 'en';
const content = legalText[lang];
---
<Layout lang={lang} currentPath="/terms" title={`${content.terms.title} — Contivo`} description={content.terms.intro}>
  <LegalPage {...content.terms} updated={content.common.updated} note={content.common.note} />
</Layout>
