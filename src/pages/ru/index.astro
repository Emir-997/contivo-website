---
import Layout from '../_layout.astro';
import HomeHero from '../../components/HomeHero.astro';
import HomeFeatures from '../../components/HomeFeatures.astro';
import { text } from '../../content/site.js';
const lang = 'ru';
const t = text[lang];
---
<Layout lang={lang} currentPath="/" title={t.home.title} description={t.home.description}>
  <HomeHero lang={lang} />
  <HomeFeatures lang={lang} />
</Layout>
