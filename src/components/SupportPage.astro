---
const { eyebrow, title, intro, cards, responseTitle, responseItems, responseNote } = Astro.props;
---
<main class="support-page">
  <section class="legal-hero">
    <div class="container legal-hero-inner">
      <span class="section-kicker">{eyebrow}</span>
      <h1>{title}</h1>
      <p>{intro}</p>
    </div>
  </section>

  <section class="container support-grid">
    {cards.map(([cardTitle, text, cta, href]) => (
      <article class="support-card">
        <span class="support-card-icon" aria-hidden="true">✦</span>
        <h2>{cardTitle}</h2>
        <p>{text}</p>
        <a class="btn btn-primary" href={href}>{cta}</a>
      </article>
    ))}
  </section>

  <section class="container support-checklist-wrap">
    <div class="support-checklist">
      <div>
        <span class="section-kicker">Contivo Support</span>
        <h2>{responseTitle}</h2>
        <p>{responseNote}</p>
      </div>
      <ul>
        {responseItems.map((item) => <li><span>✓</span>{item}</li>)}
      </ul>
    </div>
  </section>
</main>
